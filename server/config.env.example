# Arquivo de exemplo de configuracao do Servico de Edicao.
# Copie para "config.env" e ajuste os valores ao ambiente
# (ou use `npm run config` na raiz para gerar interativamente).
# config.env NAO deve ser versionado (contem segredos).

# Node: nao valida certificados TLS (uteis em redes com proxy corporativo)
NODE_TLS_REJECT_UNAUTHORIZED=0

# --- Servidor / Banco ---
PORT=3015
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=servico_edicao
DB_USER=postgres
DB_PASSWORD=troque_aqui
# Segredo JWT (gere um valor aleatorio longo, ex.: openssl rand -hex 64)
JWT_SECRET=troque_por_um_segredo_aleatorio_longo

# --- Servico de Autenticacao ---
# URL onde o servico_autenticacao esta rodando (ex.: http://localhost:3099)
AUTH_SERVER=http://localhost:3099

# --- QGIS ---
# Pasta de instalacao do QGIS (vira OSGEO4W_ROOT)
QGIS_PATH=C:\Program Files\QGIS 4.0.0
# Pasta do plugin Ferramentas de Edicao no perfil do QGIS
FE_PATH=C:\Users\SEU_USUARIO\AppData\Roaming\QGIS\QGIS4\profiles\default\python\plugins\ferramentas_edicao
# Nomes das pastas em <QGIS_PATH>\apps (variam por versao; defaults = QGIS 4.0)
QGIS_QT_DIR=Qt6
QGIS_GRASS_DIR=grass84
QGIS_PYTHON_DIR=Python312
# Pasta de plugins do perfil do QGIS (vazio = derivado de FE_PATH)
QGIS_PROFILE_PLUGINS_PATH=

# --- Servico (opcionais; valores abaixo sao os defaults) ---
# Exportacoes simultaneas do QGIS
EXPORT_CONCURRENCY=1
# Diretorio de saida dos produtos (vazio = <server>/src/export)
PATH_EXPORT=
# Rate limit da API (janela em ms e nº maximo de requisicoes por janela)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
# CORS: '*' libera todas as origens; ou lista separada por virgula
CORS_ORIGIN=*
